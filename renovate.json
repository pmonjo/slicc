{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "rebaseWhen": "conflicted",
  "automerge": true,
  "automergeType": "pr",
  "platformAutomerge": true,
  "minimumReleaseAge": "7 days",
  "internalChecksFilter": "strict",
  "vulnerabilityAlerts": {
    "minimumReleaseAge": "0 days",
    "enabled": true
  },
  "packageRules": [
    {
      "matchPackageNames": ["pyodide"],
      "rangeStrategy": "pin"
    },
    {
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "groupName": "non-major dependencies",
      "groupSlug": "non-major"
    },
    {
      "matchPackagePrefixes": ["@earendil-works/"],
      "groupName": "earendil-works packages"
    },
    {
      "matchPackagePrefixes": ["@semantic-release/"],
      "groupName": "semantic-release packages"
    },
    {
      "matchPackagePrefixes": ["@xterm/"],
      "groupName": "xterm packages"
    },
    {
      "matchPackageNames": ["s1ntoneli/AppUpdater"],
      "allowedVersions": "<1.0.0"
    },
    {
      "description": "Apply a longer 14-day cooldown for major version bumps, which carry higher risk of breaking changes and are more attractive targets for malicious actors.",
      "matchUpdateTypes": ["major"],
      "minimumReleaseAge": "14 days"
    }
  ],
  "customManagers": [
    {
      "description": "Track @ffmpeg/core version pinned in ffmpeg-wasm.ts (the wrapper does not declare it as a dependency, so renovate can't see it from package.json).",
      "customType": "regex",
      "managerFilePatterns": ["packages/webapp/src/shell/supplemental-commands/ffmpeg-wasm.ts"],
      "matchStrings": [
        "renovate: datasource=(?<datasource>.+?) depName=(?<depName>.+?)\\s+const\\s+FFMPEG_CORE_VERSION\\s*=\\s*'(?<currentValue>.+?)'"
      ]
    }
  ]
}
