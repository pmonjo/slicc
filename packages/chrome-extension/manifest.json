{
  "manifest_version": 3,
  "name": "slicc",
  "version": "0.0.0",
  "description": "AI coding agent in your browser side panel — automates tabs, edits files, and runs shell commands for web development",
  "key": "",
  "permissions": [
    "debugger",
    "tabs",
    "tabGroups",
    "sidePanel",
    "offscreen",
    "identity",
    "storage",
    "webRequest",
    "notifications"
  ],
  "host_permissions": ["<all_urls>"],
  "side_panel": {
    "default_path": "index.html"
  },
  "options_ui": {
    "page": "secrets.html",
    "open_in_tab": true
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "sandbox": {
    "pages": ["sandbox.html", "sprinkle-sandbox.html", "tool-ui-sandbox.html"]
  },
  "background": {
    "service_worker": "service-worker.js"
  },
  "action": {
    "default_title": "slicc"
  },
  "icons": {
    "16": "logos/sliccy-color-1scoops-16x16.png",
    "32": "logos/sliccy-color-1scoops-32x32.png",
    "48": "logos/sliccy-color-1scoops-48x48.png",
    "128": "logos/sliccy-color-1scoops-128x128.png"
  }
}
